
# Environment Configuration Template
# Copy this file to .env and configure with your actual values

#==============================================================================
# DATABASE CONFIGURATION
#==============================================================================

# Primary database connection string for Neon PostgreSQL
# Format: postgresql://username:password@host:port/database
# Example: postgresql://user:pass@ep-example-123.us-east-1.aws.neon.tech/socialai
DATABASE_URL="postgresql://username:password@host:port/database"

# Alternative database URL (if using multiple environments)
# Used for backup connections or read replicas
NEON_DATABASE_URL="postgresql://username:password@host:port/database"

# Database connection pool settings (optional)
DB_POOL_MIN=2                    # Minimum connections in pool
DB_POOL_MAX=10                   # Maximum connections in pool
DB_IDLE_TIMEOUT=30000            # Idle connection timeout (ms)

#==============================================================================
# AUTHENTICATION & SECURITY
#==============================================================================

# JWT secret key for token signing and verification
# SECURITY: Use a strong, random 256-bit key in production
# Generate with: openssl rand -base64 32
JWT_SECRET="your-super-secure-jwt-secret-key-minimum-32-characters"

# JWT token expiration times
JWT_EXPIRES_IN="24h"             # Access token expiration
JWT_REFRESH_EXPIRES_IN="7d"      # Refresh token expiration

# Password hashing configuration
BCRYPT_ROUNDS=12                 # Higher = more secure but slower

# Session configuration (if using sessions)
SESSION_SECRET="your-session-secret-key"
SESSION_MAX_AGE=86400000         # Session duration in milliseconds (24h)

#==============================================================================
# AYRSHARE API CONFIGURATION
#==============================================================================

# Your Ayrshare API key for social media integrations
# Obtain from: https://www.ayrshare.com/dashboard
AYRSHARE_API_KEY="your-ayrshare-api-key"

# Your Ayrshare domain ID for custom domain integration
# Used for SSO and custom branding features
AYRSHARE_DOMAIN_ID="your-ayrshare-domain-id"

# Ayrshare API base URL (usually doesn't need to change)
AYRSHARE_API_URL="https://app.ayrshare.com/api"

# RSA private key for Ayrshare JWT signing (Business plan)
# Format: Base64 encoded RSA private key
AYRSHARE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"

#==============================================================================
# SERVER CONFIGURATION
#==============================================================================

# Port for the application server
# Note: Replit uses port 5000 by default, mapped to 80/443 in production
PORT=5000

# Server host binding
# Use 0.0.0.0 for Replit deployment, localhost for local development
HOST="0.0.0.0"

# Node.js environment
# Values: development, production, test
NODE_ENV="development"

# Enable debug logging
DEBUG="socialai:*"               # Enable all debug logs
# DEBUG="socialai:auth,socialai:api"  # Enable specific debug logs

#==============================================================================
# EXTERNAL SERVICE INTEGRATIONS
#==============================================================================

# Email service configuration (for notifications)
EMAIL_SERVICE="sendgrid"         # Options: sendgrid, mailgun, smtp
EMAIL_API_KEY="your-email-service-api-key"
EMAIL_FROM="noreply@yourdomain.com"

# File upload service configuration
UPLOAD_SERVICE="cloudinary"      # Options: cloudinary, aws-s3, local
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-cloudinary-api-key"
CLOUDINARY_API_SECRET="your-cloudinary-api-secret"

# Redis configuration (for caching and sessions)
REDIS_URL="redis://localhost:6379"
REDIS_PASSWORD="your-redis-password"

#==============================================================================
# FEATURE FLAGS
#==============================================================================

# Enable/disable specific features
ENABLE_ANALYTICS=true           # Enable analytics dashboard
ENABLE_SCHEDULING=true          # Enable post scheduling
ENABLE_COMMENTS=true            # Enable comment management
ENABLE_MESSAGES=true            # Enable direct messages
ENABLE_NOTIFICATIONS=true       # Enable push notifications

# Beta features (use with caution)
ENABLE_AI_SUGGESTIONS=false     # AI-powered content suggestions
ENABLE_BULK_UPLOAD=false        # Bulk post upload feature

#==============================================================================
# DEVELOPMENT & TESTING
#==============================================================================

# Test database (separate from main database)
TEST_DATABASE_URL="postgresql://username:password@host:port/socialai_test"

# Enable development features
DEV_TOOLS=true                  # Enable development tools
MOCK_EXTERNAL_APIS=false        # Mock external API calls for testing

# Frontend development server
VITE_API_URL="http://localhost:5000"  # Backend API URL for frontend

# Logging configuration
LOG_LEVEL="info"                # Options: error, warn, info, debug
LOG_FORMAT="combined"           # Express.js log format

#==============================================================================
# PERFORMANCE & MONITORING
#==============================================================================

# Rate limiting configuration
RATE_LIMIT_WINDOW=900000        # Rate limit window (15 minutes)
RATE_LIMIT_MAX=100              # Max requests per window

# File upload limits
MAX_FILE_SIZE=10485760          # Max file size in bytes (10MB)
MAX_FILES_PER_POST=4            # Maximum files per post

# Monitoring and analytics
SENTRY_DSN="your-sentry-dsn"    # Error tracking
ANALYTICS_ID="your-analytics-id" # Google Analytics ID

#==============================================================================
# SECURITY CONFIGURATION
#==============================================================================

# CORS configuration
CORS_ORIGIN="http://localhost:3000,https://yourdomain.com"
CORS_CREDENTIALS=true

# Content Security Policy
CSP_ENABLED=true
CSP_REPORT_URI="/api/csp-report"

# SSL/TLS configuration (production)
SSL_CERT_PATH="/path/to/ssl/cert.pem"
SSL_KEY_PATH="/path/to/ssl/key.pem"

#==============================================================================
# DEPLOYMENT CONFIGURATION
#==============================================================================

# Build configuration
BUILD_TARGET="production"       # Options: development, production
SOURCE_MAPS=false              # Generate source maps for debugging

# Health check configuration
HEALTH_CHECK_INTERVAL=30000    # Health check interval (ms)
HEALTH_CHECK_TIMEOUT=5000      # Health check timeout (ms)

#==============================================================================
# NOTES
#==============================================================================

# SECURITY WARNINGS:
# - Never commit this file with real values to version control
# - Use strong, unique passwords and API keys
# - Rotate credentials regularly
# - Use environment-specific values for different deployments

# REQUIRED FOR BASIC FUNCTIONALITY:
# - DATABASE_URL
# - JWT_SECRET
# - AYRSHARE_API_KEY

# OPTIONAL BUT RECOMMENDED:
# - EMAIL_SERVICE configuration for notifications
# - REDIS_URL for improved performance
# - SENTRY_DSN for error tracking

# DEVELOPMENT vs PRODUCTION:
# - Use localhost/127.0.0.1 for local development
# - Use 0.0.0.0 for Replit and production deployments
# - Enable debug logging in development, disable in production
# - Use stronger security settings in production
